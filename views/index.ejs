<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/output.css">
</head>
<body>
    <div class="w-full h-screen bg-zinc-900 p-10 text-white">
        <div class="nav mb-10">
            <a class="text-blue-400" href="/read">Read Users</a>
        </div>
        <h1 class="text-3xl tracking-tighter mb-3">Create User</h1>
        <form action="/create" method="post">
            <input class="px-5 py-2 bg-transparent border-2 border-zinc-700 rounded-lg outline-none" type="text" name="name" placeholder="name">
            <input class="px-5 py-2 bg-transparent border-2 border-zinc-700 rounded-lg outline-none" type="email" name="email" placeholder="email">
            <input class="px-5 py-2 bg-transparent border-2 border-zinc-700 rounded-lg outline-none" type="url" name="image" placeholder="image_url">
            <input class="px-5 py-2 bg-blue-500 rounded-lg ml-3" type="submit" value="Create User">
        </form>
    </div>
</body>
</html>