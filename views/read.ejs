<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Users</title>
    <link rel="stylesheet" href="/stylesheets/output.css">
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 p-10 text-white">
        <a class="text-blue-400 hover:underline" href="/">Back to Home</a>
        <h1 class="text-3xl mt-10 tracking-tighter mb-6 font-semibold">All Users</h1>

        <div class="users flex flex-wrap gap-5">
            <% if (users.length > 0) { %>

                <% users.forEach(function(user){ %>
                    <div class="user w-72 p-4 bg-zinc-800 rounded-lg">
                        <div class="w-full h-52 rounded-lg bg-zinc-700 overflow-hidden">
                            <img class="w-full h-full object-cover" src="<%= user.image %>" alt="user image">
                        </div>

                        <h3 class="text-xl mt-4 tracking-tighter"><%= user.name %></h3>
                        <h5 class="text-zinc-400 mt-2"><%= user.email %></h5>

                        <div class="flex gap-4 mt-6">
                            <a class="text-blue-400 hover:underline" href="/edit/<%= user._id %>">Edit User</a>
                            <a class="text-red-400 hover:underline" href="/delete/<%= user._id %>">Delete User</a>
                        </div>
                    </div>
                <% }) %>

            <% } else { %>
                <h3 class="text-zinc-400 text-xl">No User Yet</h3>
            <% } %>
        </div>
    </div>
</body>
</html>